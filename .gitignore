# ============================================================
# DermAssist - Git Ignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Data & Models (large files) ---
data/raw/*
data/processed/*
data/*_Backup/
models/checkpoints/*
models/production/*.pth
models/*_backup/
!**/.gitkeep

# --- Training Artifacts ---
training_history.png
*.log

# --- OS ---
.DS_Store
Thumbs.db
